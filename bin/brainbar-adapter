#!/usr/bin/env bun

const SOCK = Bun.env.BRAINBAR_SOCKET_PATH || "/tmp/brainbar.sock";

let socket;
try {
  socket = await Bun.connect({
    unix: SOCK,
    socket: {
      data(_, data) {
        // Synchronous stdout write — Bun.write returns a Promise we can't easily
        // await from a callback without racing the close handler. process.stdout.write
        // is backed by the libuv tty/pipe write which buffers internally and flushes
        // on exit, so no data truncation on process.exit.
        process.stdout.write(data);
      },
      error(_, error) {
        console.error(`[brainbar-adapter] socket error: ${error}`);
        process.exit(1);
      },
      close() {
        // Flush any pending stdout before exiting to avoid truncating the last response.
        // process.stdout is libuv-backed; end(callback) drains before invoking the callback.
        // We always go through end() because writableFinished is only true AFTER end() has
        // been called — the conditional short-circuit would be dead code (per Bugbot LOW
        // finding on commit 774cd69).
        process.stdout.end(() => process.exit(0));
      },
    },
  });
} catch (error) {
  console.error(`[brainbar-adapter] connect failed: ${error}`);
  process.exit(1);
}

for await (const chunk of Bun.stdin.stream()) {
  let offset = 0;
  while (offset < chunk.length) {
    try {
      const written = socket.write(chunk.subarray(offset));
      if (written < 0) {
        // Socket closed or errored mid-write
        console.error(`[brainbar-adapter] socket write failed: write returned ${written}`);
        process.exit(1);
      }
      if (written === 0) {
        // Backpressure — yield to the event loop so the drain can progress, then retry
        await new Promise((resolve) => setTimeout(resolve, 10));
        continue;
      }
      offset += written;
    } catch (error) {
      console.error(`[brainbar-adapter] socket write threw: ${error}`);
      process.exit(1);
    }
  }
}

socket.end();
