#!/usr/bin/env zsh
# mcplayer — MCP process lifecycle CLI
# Phase 1 stub. cmuxlayerCodex will implement subcommands per
# ~/Gits/orchestrator/collab/2026-04-20-mcplayer-overnight-sprint.md

set -euo pipefail

VERSION="0.1.0"

typeset -ga PROC_IDS=()
typeset -ga AGENT_IDS=()
typeset -ga MCP_IDS=()
typeset -ga ORPHAN_IDS=()
typeset -gA PROC_PPID=()
typeset -gA PROC_PGID=()
typeset -gA PROC_CPU=()
typeset -gA PROC_ETIME=()
typeset -gA PROC_COMM=()
typeset -gA PROC_ARGS=()
typeset -gA PROC_KIND=()
typeset -gA PROC_LABEL=()
typeset -gA AGENT_BY_PGID=()
typeset -g BRAINBAR_PID=""
typeset -g SYSPOLICYD_CPU="0.0"
typeset -g FLAG_YES=0
typeset -g FLAG_DRY_RUN=0
typeset -g FLAG_INCLUDE_BRAINBAR=0

usage() {
  cat <<EOF
mcplayer v${VERSION} — MCP process lifecycle CLI

USAGE:
  mcplayer <subcommand> [options]

SUBCOMMANDS:
  status      One-screen dashboard: counts, load, syspolicyd %, ALARM if elevated
  list        Tree: each Claude/Codex agent → its MCP children
  orphans     Orphans only (ppid=1, agent-less)
  clean       Kill orphans (SAFE — only ppid=1). --dry-run default.
  nuke        🚨 PANIC BUTTON: kill ALL MCP+agent procs. --yes required.
  up          Ensure brainbar daemon running + healthy
  down        Graceful shutdown: agents → MCPs → brainbar
  daemon      LaunchAgent control: start|stop|status for the Phase 2 daemon

OPTIONS:
  --yes                 Confirm destructive action
  --dry-run             Print what would be done (default for clean/nuke)
  --include-brainbar    Allow nuke to kill BrainBar (default: protected)
  --version             Show version
  --help                Show this help

EXAMPLES:
  mcplayer status
  mcplayer clean              # dry-run, shows orphans
  mcplayer clean --yes        # actually kills
  mcplayer nuke --yes         # kill everything except BrainBar
  mcplayer daemon status
EOF
}

parse_flags() {
  FLAG_YES=0
  FLAG_DRY_RUN=0
  FLAG_INCLUDE_BRAINBAR=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes)
        FLAG_YES=1
        ;;
      --dry-run)
        FLAG_DRY_RUN=1
        ;;
      --include-brainbar)
        FLAG_INCLUDE_BRAINBAR=1
        ;;
      *)
        echo "Unknown option: $1" >&2
        exit 2
        ;;
    esac
    shift
  done
}

snapshot_records() {
  ps -axo pid=,ppid=,pgid=,pcpu=,etime=,comm=,args= | awk '
function classify(comm, args, text) {
  text = tolower(comm " " args)
  if (tolower(comm) ~ /brainbar$/ || args ~ /(^|[[:space:]])[^[:space:]]*BrainBar([[:space:]]|$)/) {
    return "brainbar"
  }
  if (comm ~ /^(claude|codex|cursor|gemini)$/ || text ~ /(^|[[:space:]])(claude|codex|cursor|gemini)([[:space:]]|$)/) {
    return "agent"
  }
  if (text ~ /syspolicyd/) {
    return "system"
  }
  if (comm ~ /^(bun|node|python|python3|uv|npm|socat)$/ && text ~ /(mcp|cmuxlayer|voicelayer|brainbar\.sock|brainbar-adapter|google-drive|figma|browser-tools|context7|linear|notebooklm|whatsapp-mcp)/) {
    return "mcp"
  }
  return "other"
}
function label(comm, args, text) {
  text = tolower(args)
  if (tolower(comm) == "socat" && text ~ /brainbar\.sock/) {
    return "brainbar-socket"
  }
  if (text ~ /brainbar-adapter/) {
    return "brainbar-adapter"
  }
  if (tolower(comm) ~ /brainbar/ || text ~ /brainbar/) {
    return "BrainBar"
  }
  if (text ~ /cmuxlayer/) {
    return "cmuxlayer"
  }
  if (text ~ /google-drive-mcp/) {
    return "google-drive-mcp"
  }
  if (text ~ /figma/) {
    return "figma-mcp"
  }
  if (text ~ /browser-tools/) {
    return "browser-tools-mcp"
  }
  if (text ~ /context7/) {
    return "context7-mcp"
  }
  if (text ~ /linear/) {
    return "linear-mcp"
  }
  if (text ~ /notebooklm/) {
    return "notebooklm-mcp"
  }
  if (text ~ /whatsapp-mcp/) {
    return "whatsapp-mcp"
  }
  return comm
}
{
  pid = $1
  ppid = $2
  pgid = $3
  cpu = $4
  etime = $5
  comm = $6
  args = ""
  if (NF >= 7) {
    args = $7
    for (i = 8; i <= NF; i++) {
      args = args " " $i
    }
  }
  gsub(/\|/, "/", args)
  kind = classify(comm, args)
  printf "%s|%s|%s|%s|%s|%s|%s|%s|%s\n", pid, ppid, pgid, cpu, etime, comm, args, kind, label(comm, args)
}'
}

load_snapshot() {
  PROC_IDS=()
  AGENT_IDS=()
  MCP_IDS=()
  ORPHAN_IDS=()
  PROC_PPID=()
  PROC_PGID=()
  PROC_CPU=()
  PROC_ETIME=()
  PROC_COMM=()
  PROC_ARGS=()
  PROC_KIND=()
  PROC_LABEL=()
  AGENT_BY_PGID=()
  BRAINBAR_PID=""
  SYSPOLICYD_CPU="0.0"

  local pid ppid pgid cpu etime comm args kind label
  while IFS='|' read -r pid ppid pgid cpu etime comm args kind label; do
    [[ -n "$pid" ]] || continue
    PROC_IDS+=("$pid")
    PROC_PPID[$pid]="$ppid"
    PROC_PGID[$pid]="$pgid"
    PROC_CPU[$pid]="$cpu"
    PROC_ETIME[$pid]="$etime"
    PROC_COMM[$pid]="$comm"
    PROC_ARGS[$pid]="$args"
    PROC_KIND[$pid]="$kind"
    PROC_LABEL[$pid]="$label"

    case "$kind" in
      agent)
        AGENT_IDS+=("$pid")
        AGENT_BY_PGID[$pgid]="$pid"
        ;;
      mcp)
        MCP_IDS+=("$pid")
        ;;
      brainbar)
        BRAINBAR_PID="$pid"
        ;;
      system)
        if [[ "$label" == "syspolicyd" || "$comm" == "syspolicyd" || "$args" == *"syspolicyd"* ]]; then
          SYSPOLICYD_CPU="$cpu"
        fi
        ;;
    esac
  done < <(snapshot_records)

  for pid in "${MCP_IDS[@]}"; do
    if [[ "${PROC_PPID[$pid]}" == "1" && -z "${AGENT_BY_PGID[${PROC_PGID[$pid]}]-}" ]]; then
      ORPHAN_IDS+=("$pid")
    fi
  done
}

load_average() {
  sysctl -n vm.loadavg 2>/dev/null || echo "unavailable"
}

current_brainbar_pid() {
  local pids

  if pids="$(pgrep -f BrainBar 2>/dev/null)"; then
    echo "${pids%%$'\n'*}"
    return 0
  fi

  if [[ -n "$BRAINBAR_PID" ]]; then
    echo "$BRAINBAR_PID"
    return 0
  fi

  return 1
}

kill_process() {
  local kill_bin
  local pid kill_status

  kill_bin="$(whence -p kill 2>/dev/null || true)"

  for pid in "$@"; do
    # PIDs can disappear between discovery and kill; treat that as already done.
    if [[ -n "$kill_bin" ]]; then
      if ! "$kill_bin" -0 "$pid" >/dev/null 2>&1; then
        continue
      fi
      kill_status=0
      "$kill_bin" "$pid" >/dev/null 2>&1 || kill_status=$?
      if (( kill_status == 0 )); then
        continue
      fi
      if ! "$kill_bin" -0 "$pid" >/dev/null 2>&1; then
        continue
      fi
      return "$kill_status"
    fi

    if ! kill -0 "$pid" >/dev/null 2>&1; then
      continue
    fi
    kill_status=0
    kill "$pid" >/dev/null 2>&1 || kill_status=$?
    if (( kill_status == 0 )); then
      continue
    fi
    if ! kill -0 "$pid" >/dev/null 2>&1; then
      continue
    fi
    return "$kill_status"
  done
}

start_brainbar() {
  local uid
  uid="$(id -u)"

  launchctl kickstart -k "gui/${uid}/com.brainlayer.brainbar" >/dev/null 2>&1 \
    || launchctl kickstart -k "com.brainlayer.brainbar" >/dev/null 2>&1 \
    || launchctl start "com.brainlayer.brainbar" >/dev/null 2>&1
}

print_process_line() {
  local pid="$1"
  local indent="${2:-}"

  echo "${indent}- ${PROC_LABEL[$pid]} [${pid}] ${PROC_ARGS[$pid]}"
}

status_alarm() {
  local -a reasons=()

  if (( ${#MCP_IDS[@]} > 50 )); then
    reasons+=("mcp-count=${#MCP_IDS[@]}")
  fi
  if awk -v cpu="$SYSPOLICYD_CPU" 'BEGIN { exit !((cpu + 0) > 20) }'; then
    reasons+=("syspolicyd=${SYSPOLICYD_CPU}%")
  fi

  if (( ${#reasons[@]} == 0 )); then
    echo "ok"
  else
    echo "${(j:, :)reasons}"
  fi
}

cmd_status() {
  load_snapshot

  local brainbar_state="stopped"
  local brainbar_pids
  if brainbar_pids="$(pgrep -f BrainBar 2>/dev/null)"; then
    brainbar_state="running (${brainbar_pids//$'\n'/, })"
  elif [[ -n "$BRAINBAR_PID" ]]; then
    brainbar_state="running ($BRAINBAR_PID)"
  fi

  echo "mcplayer status"
  echo "MCP procs: ${#MCP_IDS[@]} total (agents: ${#AGENT_IDS[@]}, orphans: ${#ORPHAN_IDS[@]})"
  echo "syspolicyd: ${SYSPOLICYD_CPU}%"
  echo "load: $(load_average)"
  echo "BrainBar: ${brainbar_state}"
  echo "ALARM: $(status_alarm)"
}

cmd_list() {
  load_snapshot

  local agent_pid pid

  echo "mcplayer list"
  echo "agents:"
  for agent_pid in "${AGENT_IDS[@]}"; do
    echo "- ${PROC_LABEL[$agent_pid]} [${agent_pid}] pgid=${PROC_PGID[$agent_pid]} ${PROC_ARGS[$agent_pid]}"
    for pid in "${PROC_IDS[@]}"; do
      if [[ "$pid" != "$agent_pid" && "${PROC_KIND[$pid]}" == "mcp" && "${PROC_PGID[$pid]}" == "${PROC_PGID[$agent_pid]}" ]]; then
        print_process_line "$pid" "  "
      fi
    done
  done

  echo "orphans:"
  for pid in "${ORPHAN_IDS[@]}"; do
    echo "- ${PROC_LABEL[$pid]} [${pid}] uptime=${PROC_ETIME[$pid]} ${PROC_ARGS[$pid]}"
  done
}

cmd_orphans() {
  load_snapshot

  echo "mcplayer orphans"
  for pid in "${ORPHAN_IDS[@]}"; do
    echo "- ${PROC_LABEL[$pid]} [${pid}] uptime=${PROC_ETIME[$pid]} ${PROC_ARGS[$pid]}"
  done
}

cmd_clean() {
  parse_flags "$@"
  load_snapshot

  local pid
  if (( ${#ORPHAN_IDS[@]} == 0 )); then
    echo "mcplayer clean"
    echo "no orphan runtimes found"
    return 0
  fi

  echo "mcplayer clean"
  if (( FLAG_YES == 0 || FLAG_DRY_RUN == 1 )); then
    echo "dry-run: would kill orphan runtimes"
    for pid in "${ORPHAN_IDS[@]}"; do
      echo "- ${PROC_LABEL[$pid]} [${pid}]"
    done
    return 0
  fi

  for pid in "${ORPHAN_IDS[@]}"; do
    kill_process "$pid"
    echo "killed ${PROC_LABEL[$pid]} [${pid}]"
  done
}

cmd_nuke() {
  parse_flags "$@"
  load_snapshot

  local pid
  local brainbar_pid=""
  local dry_run=0
  local -a target_ids=()

  echo "mcplayer nuke"
  target_ids=("${AGENT_IDS[@]}" "${MCP_IDS[@]}")
  brainbar_pid="$(current_brainbar_pid 2>/dev/null || true)"
  if (( FLAG_DRY_RUN == 1 || FLAG_YES == 0 )); then
    dry_run=1
  fi

  if (( dry_run == 1 )); then
    echo "dry-run: would kill agent and MCP runtimes"
    for pid in "${target_ids[@]}"; do
      echo "- ${PROC_LABEL[$pid]} [${pid}]"
    done
    if [[ -n "$brainbar_pid" ]]; then
      if (( FLAG_INCLUDE_BRAINBAR == 1 )); then
        echo "- BrainBar [${brainbar_pid}]"
      else
        echo "- BrainBar [${brainbar_pid}] protected"
      fi
    fi
    return 0
  fi

  for pid in "${AGENT_IDS[@]}"; do
    kill_process "$pid"
    echo "killed agent ${PROC_LABEL[$pid]} [${pid}]"
  done
  for pid in "${MCP_IDS[@]}"; do
    kill_process "$pid"
    echo "killed mcp ${PROC_LABEL[$pid]} [${pid}]"
  done

  if [[ -n "$brainbar_pid" ]]; then
    if (( FLAG_INCLUDE_BRAINBAR == 1 )); then
      kill_process "$brainbar_pid"
      echo "killed BrainBar [${brainbar_pid}]"
    else
      echo "protected BrainBar [${brainbar_pid}]"
    fi
  fi
}

cmd_up() {
  parse_flags "$@"

  local brainbar_pid
  brainbar_pid="$(current_brainbar_pid 2>/dev/null || true)"
  if [[ -n "$brainbar_pid" ]]; then
    echo "mcplayer up"
    echo "BrainBar already running [${brainbar_pid}]"
    return 0
  fi

  start_brainbar

  brainbar_pid="$(current_brainbar_pid 2>/dev/null || true)"
  echo "mcplayer up"
  if [[ -n "$brainbar_pid" ]]; then
    echo "BrainBar running [${brainbar_pid}]"
    return 0
  fi

  echo "BrainBar failed to start" >&2
  return 1
}

cmd_down() {
  parse_flags "$@"
  load_snapshot

  local pid
  local brainbar_pid
  brainbar_pid="$(current_brainbar_pid 2>/dev/null || true)"

  echo "mcplayer down"
  echo "graceful shutdown order:"
  echo "1. agents"
  echo "2. mcp"
  if [[ -n "$brainbar_pid" ]]; then
    if (( FLAG_INCLUDE_BRAINBAR == 1 )); then
      echo "3. brainbar"
    else
      echo "3. brainbar (protected)"
    fi
  else
    echo "3. brainbar"
  fi

  if (( FLAG_YES == 0 || FLAG_DRY_RUN == 1 )); then
    echo "dry-run: pass --yes to execute"
    return 0
  fi

  for pid in "${AGENT_IDS[@]}"; do
    kill_process "$pid"
    echo "stopped agent ${PROC_LABEL[$pid]} [${pid}]"
  done
  for pid in "${MCP_IDS[@]}"; do
    kill_process "$pid"
    echo "stopped mcp ${PROC_LABEL[$pid]} [${pid}]"
  done

  if [[ -n "$brainbar_pid" ]] && (( FLAG_INCLUDE_BRAINBAR == 1 )); then
    kill_process "$brainbar_pid"
    echo "stopped brainbar [${brainbar_pid}]"
  fi
}

daemon_label() {
  echo "${MCPLAYER_DAEMON_LABEL:-com.mcplayer.multiplexer}"
}

daemon_socket_path() {
  echo "${MCPLAYER_SOCKET_PATH:-/tmp/mcplayer.sock}"
}

daemon_launchd_target() {
  local uid
  uid="$(id -u)"
  echo "gui/${uid}/$(daemon_label)"
}

cmd_daemon_start() {
  parse_flags "$@"

  local target
  target="$(daemon_launchd_target)"

  echo "mcplayer daemon start"
  if ! launchctl kickstart -k "$target" >/dev/null 2>&1; then
    echo "failed: launchctl kickstart -k $target" >&2
    return 1
  fi

  echo "launchctl kickstart -k $target"
}

cmd_daemon_stop() {
  parse_flags "$@"

  local target plist_path
  target="$(daemon_launchd_target)"
  plist_path="$HOME/Library/LaunchAgents/$(daemon_label).plist"

  echo "mcplayer daemon stop"
  if launchctl bootout "$target" >/dev/null 2>&1; then
    echo "launchctl bootout $target"
    return 0
  fi

  if launchctl bootout "gui/$(id -u)" "$plist_path" >/dev/null 2>&1; then
    echo "launchctl bootout gui/$(id -u) $plist_path"
    return 0
  fi

  echo "failed: launchctl bootout $target" >&2
  echo "failed: launchctl bootout gui/$(id -u) $plist_path" >&2
  return 1
}

cmd_daemon_status() {
  parse_flags "$@"

  local socket_path status_payload
  socket_path="$(daemon_socket_path)"

  echo "mcplayer daemon status"
  if ! status_payload="$(printf 'CONTROL:status\n' | nc -U "$socket_path" 2>/dev/null)"; then
    echo "daemon unavailable at $socket_path" >&2
    return 1
  fi

  if [[ -z "$status_payload" ]]; then
    echo "empty status payload from $socket_path" >&2
    return 1
  fi

  echo "$status_payload"
}

cmd="${1:-}"
case "$cmd" in
  status)
    cmd_status "${@:2}"
    ;;
  list)
    cmd_list "${@:2}"
    ;;
  orphans)
    cmd_orphans "${@:2}"
    ;;
  clean)
    cmd_clean "${@:2}"
    ;;
  nuke)
    cmd_nuke "${@:2}"
    ;;
  up)
    cmd_up "${@:2}"
    ;;
  down)
    cmd_down "${@:2}"
    ;;
  daemon)
    daemon_cmd="${2:-}"
    case "$daemon_cmd" in
      start)
        cmd_daemon_start "${@:3}"
        ;;
      stop)
        cmd_daemon_stop "${@:3}"
        ;;
      status)
        cmd_daemon_status "${@:3}"
        ;;
      *)
        echo "Usage: mcplayer daemon <start|stop|status>" >&2
        exit 2
        ;;
    esac
    ;;
  --version|-v)
    echo "mcplayer $VERSION"
    ;;
  --help|-h|"")
    usage
    ;;
  *)
    echo "Unknown subcommand: $cmd"
    echo ""
    usage
    exit 2
    ;;
esac
